# Database Configuration
DATABASE_URL=postgres://release_engine:release_engine@localhost:6432/release_engine?sslmode=disable

# OIDC Configuration
OIDC_ISSUER_URL=http://localhost:5556/dex
OIDC_AUDIENCE=release-engine

# HTTP Server Configuration
HTTP_PORT=8080
LOG_LEVEL=debug

# MinIO Configuration (for Volta S3 storage)
VOLTA_ENV=dev
VOLTA_STORAGE=s3
VOLTA_S3_BUCKET=volta-secrets
VOLTA_MASTER_PASSPHRASE=dev-secure-passphrase
VOLTA_SM_SECRET_ID=release-engine/volta-master-passphrase

# MinIO S3 endpoint
AWS_ENDPOINT=localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
RE_ALLOW_PRIVATE_CALLBACKS=true
