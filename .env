# Database Configuration
DATABASE_URL=postgres://release_engine:release_engine@localhost:5432/release_engine

# Application Configuration
HTTP_PORT=8080
LOG_LEVEL=debug

# OIDC Configuration (Phase 1)
OIDC_ISSUER_URL=http://localhost:5556/dex
OIDC_AUDIENCE=release-engine

# DORA Configuration
DORA_PROMETHEUS_ENABLED=true

# Volta Configuration (Phase 3)
VOLTA_ENV=dev
VOLTA_STORAGE=file
VOLTA_FILE_PATH=/tmp/volta/vaults
VOLTA_SM_SECRET_ID=release-engine/volta-master-passphrase
VOLTA_S3_BUCKET=release-engine-volta
VOLTA_MASTER_PASSPHRASE=dev-secure-passphrase

# Job Execution and API Timeout Configuration
JOB_EXECUTION_TIMEOUT=45s
API_CLIENT_TIMEOUT=30s
