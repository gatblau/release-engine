# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=release_engine

# NATS Configuration
NATS_URL=nats://localhost:4222

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Application Configuration
SERVER_PORT=8080
LOG_LEVEL=info
# DORA Prometheus metrics toggle (default true)
DORA_PROMETHEUS_ENABLED=true

# Volta Configuration
# VOLTA_ENV: dev or prod (default: prod)
# VOLTA_STORAGE: s3 or file (default: s3)
# VOLTA_FILE_PATH: path for file-based storage (used when VOLTA_STORAGE=file)
# VOLTA_S3_BUCKET: S3 bucket for vault storage (required for prod)
# VOLTA_SM_SECRET_ID: AWS Secrets Manager secret ID for master passphrase (required for prod)
# VOLTA_SALT: optional salt for dev mode (optional)
# VOLTA_MASTER_PASSPHRASE: optional passphrase for dev mode (optional, for prod use Secrets Manager)
# VOLTA_PASSPHRASE_ENV_VAR: optional custom env var name for passphrase (default: VOLTA_MASTER_PASSPHRASE)
VOLTA_ENV=dev
VOLTA_STORAGE=file
VOLTA_FILE_PATH=/tmp/volta/vaults
VOLTA_S3_BUCKET=release-engine-volta
VOLTA_SM_SECRET_ID=release-engine/volta-master-passphrase
VOLTA_SALT=dev-stable-salt-value
VOLTA_MASTER_PASSPHRASE=dev-secure-passphrase
